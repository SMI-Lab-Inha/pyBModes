    orcid: "https://orcid.org/0000-0003-1047-2119" 
version: 1.15.1
date-released: "2026-05-30"
license: Apache-2.0
repository-code: "https://github.com/SMI-Lab-Inha/pyBModes"
url: "https://github.com/SMI-Lab-Inha/pyBModes"
keywords:
